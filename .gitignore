## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio extensions.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider IDE
.idea/
*.sln.iml

# NuGet Package Manager
*.nupkg
*.snupkg

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# dotnet user secrets
secrets.json

# Visual Studio generated files
.cache/

# OS Files
.DS_Store
Thumbs.db

# IDE files
*.code-workspace